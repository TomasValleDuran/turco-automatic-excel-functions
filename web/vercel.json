{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python", "config": { "maxDuration": 60 } },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/daily", "dest": "/api/daily.py" },
    { "src": "/api/monthly", "dest": "/api/monthly.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
